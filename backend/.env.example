# HackForums OAuth app credentials
# Create your app at: https://hackforums.net/usercp.php?action=options -> API Management
HF_CLIENT_ID=your_client_id_here
HF_CLIENT_SECRET=your_client_secret_here
HF_REDIRECT_URI=https://yourdomain.com/auth/callback

# Session security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change_this_to_a_random_secret

# Token encryption key — used to encrypt stored HF OAuth tokens at rest
# If not set, derived from SESSION_SECRET automatically
# Generate a dedicated key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TOKEN_ENCRYPT_KEY=your_fernet_key_here

# Your frontend URL (used for CORS and OAuth redirect)
FRONTEND_URL=https://yourdomain.com

# Optional: residential proxy URL if running on a datacenter IP (Cloudflare blocks them)
# Format: http://user:password@host:port  or  socks5://user:password@host:port
# HF_PROXY_URL=http://user:pass@proxy.example.com:8080

# Environment (development or production)
ENV=production
